PORT=3000
CATALOG_DATA_SOURCE=mysql
AUTH_PROVIDER=local

# Use either the DB_* variables below or Railway MySQL variables
# (MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE).
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=piefruits

JWT_SECRET=change_me
ADMIN_ID=admin
ADMIN_PASSWORD=change_me

# ── Razorpay ──
# From Razorpay Dashboard → Settings → API Keys (use rzp_test_* for testing).
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=change_me
# From Dashboard → Settings → Webhooks. Create a webhook pointing to
# <your-api-url>/api/payment/webhook, subscribe to the "payment.captured" event,
# and paste the secret you set here. Until then online payments still work via the
# client verify flow; the webhook is a server-side safety net.
RAZORPAY_WEBHOOK_SECRET=change_me

CONTACT_TO_EMAIL=your_inbox@example.com
BREVO_API_KEY=
BREVO_FROM_EMAIL=verified_sender@example.com
BREVO_FROM_NAME=Pie Foods
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Comma-separated list of allowed browser origins for the deployed frontend.
# Any localhost/127.0.0.1 port is always allowed in addition to these.
# e.g. CORS_ALLOWED_ORIGINS=https://mangofarm.com,https://www.mangofarm.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_BASE_URL=https://your-public-bucket-url.r2.dev

# Local dev can use FIREBASE_SERVICE_ACCOUNT_PATH. Hosted deploys should use
# FIREBASE_PROJECT_ID + FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY instead.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_WEB_API_KEY=AIzaSyCKqrc0LuDZZsfdAnQEf_IOq161KRiOuWE
FIREBASE_ADMIN_EMAILS=admin@example.com
FIREBASE_USERS_COLLECTION=users
FIREBASE_CATEGORIES_COLLECTION=categories
FIREBASE_PRODUCTS_COLLECTION=products
FIREBASE_COMBOS_COLLECTION=combos
FIREBASE_BANNERS_COLLECTION=banners
FIREBASE_POPULAR_PRODUCTS_COLLECTION=popular_products
